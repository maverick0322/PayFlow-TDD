import pytest


from payflow import _asegurar_numero_no_negativo, validar_presupuesto


@pytest.mark.parametrize(
    "pmt,ahorro_meta,serv_hist,susc_fijas,ocio_hist,estado_esperado,alertas_esperadas",
    [
        # Test 1: Si el PMT no cubre el Ahorro, estado = EJERCICIO_DEFICIT.
        (999, 1000, 100, 50, 25, "EJERCICIO_DEFICIT", ["Deficit detectado en Ahorro"]),
        # Test 2: Cubre Ahorro pero no Servicios -> alerta Servicios.
        (1100, 1000, 200, 50, 25, "EJERCICIO_DEFICIT", ["Deficit detectado en Servicios"]),
        # Test 3: Cubre hasta Servicios pero no Suscripciones -> alerta Suscripciones.
        (1300, 1000, 200, 200, 25, "EJERCICIO_DEFICIT", ["Deficit detectado en Suscripciones"]),
        # Test 4: Cubre hasta Suscripciones pero no Ocio -> alerta Ocio.
        (1500, 1000, 200, 200, 200, "EJERCICIO_DEFICIT", ["Deficit detectado en Ocio"]),
        # Test 5: Flujo feliz cubre las 4 prioridades -> EJERCICIO y sin alertas.
        (2000, 1000, 200, 200, 200, "EJERCICIO", []),
    ],
)
def test_priorizacion_por_jerarquia(
    pmt,
    ahorro_meta,
    serv_hist,
    susc_fijas,
    ocio_hist,
    estado_esperado,
    alertas_esperadas,
):
    estado, alertas = validar_presupuesto(pmt, ahorro_meta, serv_hist, susc_fijas, ocio_hist)
    assert estado == estado_esperado
    assert alertas == alertas_esperadas


@pytest.mark.parametrize(
    "kwargs,mensaje",
    [
        (dict(pmt=0, ahorro_meta=1, serv_hist=1, susc_fijas=1, ocio_hist=1), "PMT debe ser mayor que cero"),
        (dict(pmt=-1, ahorro_meta=1, serv_hist=1, susc_fijas=1, ocio_hist=1), "PMT no puede ser negativo"),
        (dict(pmt=1, ahorro_meta=-1, serv_hist=1, susc_fijas=1, ocio_hist=1), "Ahorro no puede ser negativo"),
        (dict(pmt=1, ahorro_meta=1, serv_hist=-1, susc_fijas=1, ocio_hist=1), "Servicios no puede ser negativo"),
        (dict(pmt=1, ahorro_meta=1, serv_hist=1, susc_fijas=-1, ocio_hist=1), "Suscripciones no puede ser negativo"),
        (dict(pmt=1, ahorro_meta=1, serv_hist=1, susc_fijas=1, ocio_hist=-1), "Ocio no puede ser negativo"),
    ],
)
def test_validaciones_de_valores_requeridos(kwargs, mensaje):
    with pytest.raises(ValueError, match=mensaje):
        validar_presupuesto(**kwargs)


@pytest.mark.parametrize(
    "kwargs",
    [
        dict(pmt="100", ahorro_meta=1, serv_hist=1, susc_fijas=1, ocio_hist=1),
        dict(pmt=100, ahorro_meta="1", serv_hist=1, susc_fijas=1, ocio_hist=1),
        dict(pmt=100, ahorro_meta=1, serv_hist=None, susc_fijas=1, ocio_hist=1),
    ],
)
def test_validaciones_tipo_numerico(kwargs):
    with pytest.raises(TypeError):
        validar_presupuesto(**kwargs)


def test_validacion_negativo_generica_para_nombre_desconocido():
    with pytest.raises(ValueError, match="Algo no puede ser negativo"):
        _asegurar_numero_no_negativo("Algo", -1)
